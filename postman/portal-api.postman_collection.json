{
  "info": {
    "_postman_id": "6f783d79-2af8-454e-a30a-78f36fdbb4ef",
    "name": "Portal API (bot-1c.ru)",
    "description": "Коллекция для проверки портала и Telegram webhook.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01. Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02. Login (save token)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Has access token', function () {",
              "  pm.expect(json.access_token).to.be.a('string').and.not.empty;",
              "});",
              "pm.environment.set('token', json.access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "03. Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "me"
          ]
        }
      }
    },
    {
      "name": "04. Organization",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/org",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "org"
          ]
        }
      }
    },
    {
      "name": "05. Billing Limits",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/billing/limits",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "billing",
            "limits"
          ]
        }
      }
    },
    {
      "name": "06. Create Bot (save botId)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Test Bot\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/bots",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "bots"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Has bot id', function () {",
              "  pm.expect(json.id).to.exist;",
              "});",
              "pm.environment.set('botId', String(json.id));"
            ]
          }
        }
      ]
    },
    {
      "name": "07. Connect Telegram Webhook",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{telegramToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/bots/{{botId}}/telegram",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "bots",
            "{{botId}}",
            "telegram"
          ]
        }
      }
    },
    {
      "name": "08. List Bot Messages",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/bots/{{botId}}/messages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "bots",
            "{{botId}}",
            "messages"
          ]
        }
      }
    },
    {
      "name": "09. Webhook Reachability (dummy secret)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": {\n    \"text\": \"ping from postman\",\n    \"chat\": { \"id\": 123456789 }\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/webhooks/telegram/test-secret",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "webhooks",
            "telegram",
            "test-secret"
          ]
        }
      }
    }
  ]
}
